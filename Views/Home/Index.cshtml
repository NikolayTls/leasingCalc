@{
    ViewData["Title"] = "Кредитен калкулатор";
}

<section class="calculator">
    <h2>Лизингов калкулатор за покупка на стоки</h2>
    <p>Пресметнете оскъпяването на стоката, закупена чрез лизинг</p>

    <div class="form-row">
        <div class="form-group">
            <label>Цена на стоката с ДДС *</label>
            <input id="itemPrice" type="number" step="0.01" />
            <div class="error-msg" id="err-itemPrice"></div>
        </div>
        <div class="form-group">
            <label>Първоначална вноска *</label>
            <input id="downPayment" type="number" step="0.01" />
            <div class="error-msg" id="err-downPayment"></div>
        </div>
    </div>
    
    <div class="form-row">
        <div class="form-group">
            <label>Срок на лизинга (месеци) *</label>
            <input id="months" type="number" step="1" />
            <div class="error-msg" id="err-months"></div>
        </div>
        <div class="form-group">
            <label>Месечна вноска *</label>
            <input id="monthlyInstallment" type="number" step="0.01" />
            <div class="error-msg" id="err-monthlyInstallment"></div>
        </div>
    </div>
    
    <div class="form-row">
        <div class="form-group">
            <label>Първоначална такса за обработка %</label>
            <input id="processingFeePercentage" type="number" step="0.01" />
            <div class="error-msg" id="err-processingFeePercentage"></div>
        </div>
    </div>

    <p class="required-note">*Задължителни полета</p>

    <button id="btnCalculate">ИЗЧИСЛИ</button>

    <div id="result" style="display:none;">
        <h3>Резултати</h3>
        <p>ГОДИШЕН ПРОЦЕНТЕН РАЗХОД: <span id="apr"></span> %</p>
        <p>ОБЩО ИЗПЛАТЕНО С ТАКСИ: <span id="totalPaid"></span> BGN</p>
        <p>ОБЩО ТАКСИ: <span id="totalFees"></span> BGN</p>
    </div>
</section>

<link rel="stylesheet" href="~/css/calculator.css" />